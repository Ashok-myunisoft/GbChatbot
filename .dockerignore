# Secrets — never bake into the image
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/

# Local vectorstore data (mount via volume instead)
memory_vectorstore_formula/
memory_vectorstore_report/
conversational_memory_vectorstore/
menu_memory_vectorstore/

# Data files (mount via volume instead)
data/

# Dev / editor artefacts
.git/
.gitignore
*.md
.DS_Store
.idea/
.vscode/

# Docker files (no need to copy into image)
Dockerfile
docker-compose.yml

# Dev / utility scripts (not needed at runtime)
db_setup.py

# Temp / log files
*.log
*.tmp
